.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's environment. But for an application, you might want to
#   check them in.
# .python-version

# pipenv
#   According to pypa/pipenv#1263, we should ignore Pipfile.lock if we are recommending
#   multi-stage builds or packaging. But since this is a decoupled application project,
#   checking it in is fine, although we rely on requirements.txt.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is optionally ignored.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is optionally ignored.
# pdm.lock

# PEP 582; project local packages (e.g. pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

