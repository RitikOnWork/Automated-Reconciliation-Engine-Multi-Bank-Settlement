# ==============================================================================
# Automated Reconciliation Engine - Environment Configuration Template
# Copy this file to '.env' and modify the values for your environment.
# ==============================================================================

# Core Application Settings
PROJECT_NAME="Automated Reconciliation Engine"
ENVIRONMENT=development
API_V1_STR=/api/v1
DEBUG=true

# Security Settings
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=949f1db8dfde7b864a7cd254c6001d9f828a2a8b94154425712adcd5b36440c9
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days (for development, configure shorter in production)

# Database Connection (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=recon_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy database connection string (automatically built by config.py if not specified)
# DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/recon_db

# CORS Configuration (comma-separated list of origins)
BACKEND_CORS_ORIGINS=http://localhost:8501,http://localhost:8000,http://127.0.0.1:8501

# Streamlit Frontend Settings
# URL pointing to the FastAPI backend service
BACKEND_API_URL=http://backend:8000/api/v1
# Host & Port Streamlit runs on (inside the docker context)
FRONTEND_PORT=8501
