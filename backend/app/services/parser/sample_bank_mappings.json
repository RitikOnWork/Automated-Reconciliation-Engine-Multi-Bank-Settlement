{
  "chase_format_standard": {
    "bank_name": "Chase Commercial Statement",
    "delimiter": ",",
    "skip_rows": 0,
    "has_header": true,
    "column_mapping": {
      "transaction_date": "Posting Date",
      "value_date": "Value Date",
      "amount": "Amount",
      "currency": "Currency",
      "reference": "Reference Number",
      "description": "Description",
      "bank_account": "Account Number"
    },
    "date_formats": [
      "%m/%d/%Y",
      "%Y-%m-%d"
    ],
    "defaults": {
      "currency": "USD"
    }
  },
  "citi_format_european": {
    "bank_name": "Citi European Ledger",
