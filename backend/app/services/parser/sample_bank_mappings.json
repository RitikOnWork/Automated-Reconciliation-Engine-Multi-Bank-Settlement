    },
    "date_formats": [
      "%d.%m.%Y",
      "%d/%m/%Y"
    ],
    "defaults": {
      "currency": "EUR"
    }
  },
  "barclays_format_custom": {
    "bank_name": "Barclays Corporate Ledger",
    "delimiter": "\t",
    "skip_rows": 3,
    "has_header": true,
    "column_mapping": {
      "transaction_date": "Transaction Date",
      "amount": "Ledger Balance Change",
